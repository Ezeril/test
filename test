-- ServerScriptService > WeaponTracer
local Players = game:GetService("Players")
local CollectionService = game:GetService("CollectionService")

local WEAPON_TAGS = {
	Weapon = true,
	Weapon_Knife = true,
	Weapon_Gun = true,
}

local alreadyLogged = setmetatable({}, { __mode = "k" })

local function getTags(instance)
	local tags = {}

	for _, tag in CollectionService:GetTags(instance) do
		table.insert(tags, tag)
	end

	return #tags > 0 and table.concat(tags, ", ") or "aucun"
end

local function getAttributes(instance)
	local result = {}

	for key, value in pairs(instance:GetAttributes()) do
		table.insert(result, key .. " = " .. tostring(value))
	end

	return #result > 0 and table.concat(result, " | ") or "aucun"
end

local function isWeapon(instance)
	if not instance:IsA("Tool") then
		return false
	end

	for tag in pairs(WEAPON_TAGS) do
		if instance:HasTag(tag) then
			return true
		end
	end

	return false
end

local function logWeapon(tool, reason)
	if alreadyLogged[tool] then
		return
	end

	alreadyLogged[tool] = true

	print("\n========== ARME DETECTEE ==========")
	print("Raison :", reason)
	print("Nom :", tool.Name)
	print("Classe :", tool.ClassName)
	print("Parent actuel :", tool.Parent and tool.Parent:GetFullName() or "nil")
	print("Chemin :", tool:GetFullName())
	print("Tags :", getTags(tool))
	print("Attributs :", getAttributes(tool))
	print("Enfants :", #tool:GetChildren())

	for _, child in ipairs(tool:GetChildren()) do
		print("  -", child.ClassName, child.Name)
	end

	tool:GetPropertyChangedSignal("Parent"):Connect(function()
		print(
			"[WeaponTracer] " .. tool.Name .. " a changé de parent ->",
			tool.Parent and tool.Parent:GetFullName() or "nil"
		)
	end)
end

local function watchContainer(container)
	for _, child in ipairs(container:GetChildren()) do
		if isWeapon(child) then
			logWeapon(child, "déjà présent au démarrage")
		end
	end

	container.ChildAdded:Connect(function(child)
		task.wait()

		if isWeapon(child) then
			logWeapon(child, "ajouté dans " .. container:GetFullName())
		end
	end)
end

local function watchPlayer(player)
	local function watchCharacter(character)
		watchContainer(character)
	end

	watchContainer(player:WaitForChild("Backpack"))

	if player.Character then
		watchCharacter(player.Character)
	end

	player.CharacterAdded:Connect(watchCharacter)
end

-- Arme taguée après sa création
for tag in pairs(WEAPON_TAGS) do
	CollectionService:GetInstanceAddedSignal(tag):Connect(function(instance)
		if instance:IsA("Tool") then
			logWeapon(instance, "tag ajouté : " .. tag)
		end
	end)
end

-- Armes déjà taguées avant le lancement du traceur
for tag in pairs(WEAPON_TAGS) do
	for _, instance in ipairs(CollectionService:GetTagged(tag)) do
		if instance:IsA("Tool") then
			logWeapon(instance, "tag déjà existant : " .. tag)
		end
	end
end

Players.PlayerAdded:Connect(watchPlayer)

for _, player in ipairs(Players:GetPlayers()) do
	task.spawn(watchPlayer, player)
end

print("[WeaponTracer] Actif : lance une manche et obtiens Murderer ou Sheriff.")
