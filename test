-- ServerScriptService > WeaponCollector
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local CollectionService = game:GetService("CollectionService")

local backupFolder = ReplicatedStorage:FindFirstChild("WeaponsBackup")

if not backupFolder then
	backupFolder = Instance.new("Folder")
	backupFolder.Name = "WeaponsBackup"
	backupFolder.Parent = ReplicatedStorage
end

local collected = {}

local function safeName(text)
	text = tostring(text or "UnknownWeapon")
	return text:gsub("[^%w_%-]", "_")
end

local function collectWeapon(tool, reason)
	if not tool:IsA("Tool") then
		return
	end

	if not tool:HasTag("Weapon") then
		return
	end

	-- Laisse le Tool se remplir : Handle, scripts, animations, sons, Shoot...
	task.wait(0.5)

	if not tool.Parent then
		return
	end

	local itemId = tool:GetAttribute("ItemID")
	local itemName = tool:GetAttribute("ItemName")
	local weaponType = tool:GetAttribute("ItemType")

	local uniqueId = itemId or itemName or tool.Name

	if collected[uniqueId] or backupFolder:FindFirstChild(safeName(uniqueId)) then
		return
	end

	local copy = tool:Clone()
	copy.Name = safeName(uniqueId)
	copy:SetAttribute("OriginalToolName", tool.Name)
	copy:SetAttribute("CollectedFrom", tool.Parent:GetFullName())
	copy:SetAttribute("CollectedReason", reason)

	copy.Parent = backupFolder
	collected[uniqueId] = true

	print("\n========== ARME SAUVEGARDEE ==========")
	print("ID :", uniqueId)
	print("Nom :", itemName or tool.Name)
	print("Type :", weaponType or "inconnu")
	print("Dossier :", copy:GetFullName())
	print("Enfants :", #copy:GetChildren())
end

local function watchPlayer(player)
	local backpack = player:WaitForChild("Backpack")

	backpack.ChildAdded:Connect(function(child)
		task.spawn(collectWeapon, child, "ajoutée au Backpack de " .. player.Name)
	end)

	for _, child in ipairs(backpack:GetChildren()) do
		task.spawn(collectWeapon, child, "déjà dans Backpack de " .. player.Name)
	end
end

-- Cas où le tag Weapon est ajouté après que le Tool existe.
CollectionService:GetInstanceAddedSignal("Weapon"):Connect(function(instance)
	task.spawn(collectWeapon, instance, "tag Weapon ajouté")
end)

for _, instance in ipairs(CollectionService:GetTagged("Weapon")) do
	task.spawn(collectWeapon, instance, "tag Weapon déjà présent")
end

game.Players.PlayerAdded:Connect(watchPlayer)

for _, player in ipairs(game.Players:GetPlayers()) do
	task.spawn(watchPlayer, player)
end

print("[WeaponCollector] Actif : les armes collectées iront dans ReplicatedStorage.WeaponsBackup")
