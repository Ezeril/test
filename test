-- ServerScriptService > RuntimeWeaponTracer
local Players = game:GetService("Players")
local CollectionService = game:GetService("CollectionService")

local WEAPON_TAGS = {
	Weapon = true,
	Weapon_Gun = true,
	Weapon_Knife = true,
}

local watchedTools = setmetatable({}, { __mode = "k" })
local watchedScripts = setmetatable({}, { __mode = "k" })

local function fullName(instance)
	local ok, result = pcall(function()
		return instance:GetFullName()
	end)

	return ok and result or instance.Name
end

local function tagsToText(instance)
	local tags = CollectionService:GetTags(instance)
	return #tags > 0 and table.concat(tags, ", ") or "aucun"
end

local function attributesToText(instance)
	local parts = {}

	for name, value in pairs(instance:GetAttributes()) do
		table.insert(parts, name .. " = " .. tostring(value))
	end

	table.sort(parts)
	return #parts > 0 and table.concat(parts, " | ") or "aucun"
end

local function isWeapon(tool)
	if not tool:IsA("Tool") then
		return false
	end

	if tool.Name == "Gun" or tool.Name == "Knife" then
		return true
	end

	for tag in pairs(WEAPON_TAGS) do
		if tool:HasTag(tag) then
			return true
		end
	end

	return tool:GetAttribute("IsWeapon") == true
end

local function watchTool(tool, reason)
	if watchedTools[tool] or not isWeapon(tool) then
		return
	end

	watchedTools[tool] = true

	print("\n================ ARME RUNTIME ================")
	print("Raison :", reason)
	print("Nom :", tool.Name)
	print("Chemin :", fullName(tool))
	print("Parent :", tool.Parent and fullName(tool.Parent) or "nil")
	print("Tags :", tagsToText(tool))
	print("Attributs :", attributesToText(tool))
	print("Enfants :", #tool:GetChildren())

	for _, child in ipairs(tool:GetChildren()) do
		print("  Enfant :", child.ClassName, child.Name)
	end

	tool.ChildAdded:Connect(function(child)
		print("[ARME ENFANT AJOUTÉ]", tool.Name, "->", child.ClassName, child.Name)
	end)

	tool.AttributeChanged:Connect(function(attributeName)
		print(
			"[ARME ATTRIBUT MODIFIÉ]",
			tool.Name,
			attributeName,
			"=",
			tostring(tool:GetAttribute(attributeName))
		)
	end)

	tool:GetPropertyChangedSignal("Parent"):Connect(function()
		print(
			"[ARME PARENT CHANGE]",
			tool.Name,
			"->",
			tool.Parent and fullName(tool.Parent) or "nil"
		)
	end)

	tool.Destroying:Connect(function()
		print("[ARME DÉTRUITE]", tool.Name, "dernier chemin :", fullName(tool))
	end)
end

local function watchScript(scriptObject, reason)
	if watchedScripts[scriptObject] then
		return
	end

	watchedScripts[scriptObject] = true

	print("\n[NEW SCRIPT RUNTIME]")
	print("Raison :", reason)
	print("Classe :", scriptObject.ClassName)
	print("Chemin :", fullName(scriptObject))

	if scriptObject:IsA("ModuleScript") then
		print("Nom ModuleScript :", scriptObject.Name)
	end
end

local function inspect(instance, reason)
	if instance:IsA("Tool") then
		task.defer(watchTool, instance, reason)
	end

	if instance:IsA("Script") or instance:IsA("LocalScript") or instance:IsA("ModuleScript") then
		watchScript(instance, reason)
	end
end

-- Surveille chaque service où des objets peuvent être créés ou déplacés.
local ROOTS = {
	workspace,
	game:GetService("ReplicatedStorage"),
	game:GetService("ServerStorage"),
	game:GetService("ServerScriptService"),
}

for _, root in ipairs(ROOTS) do
	root.DescendantAdded:Connect(function(instance)
		inspect(instance, "DescendantAdded dans " .. root.Name)
	end)

	for _, instance in ipairs(root:GetDescendants()) do
		inspect(instance, "déjà présent dans " .. root.Name)
	end
end

local function watchPlayer(player)
	local backpack = player:WaitForChild("Backpack")

	backpack.ChildAdded:Connect(function(instance)
		inspect(instance, "ajouté au Backpack de " .. player.Name)
	end)

	player.CharacterAdded:Connect(function(character)
		character.ChildAdded:Connect(function(instance)
			inspect(instance, "ajouté au Character de " .. player.Name)
		end)
	end)

	for _, instance in ipairs(backpack:GetChildren()) do
		inspect(instance, "déjà dans Backpack de " .. player.Name)
	end
end

Players.PlayerAdded:Connect(watchPlayer)

for _, player in ipairs(Players:GetPlayers()) do
	task.spawn(watchPlayer, player)
end

-- Détection lorsque les tags sont ajoutés après la création du Tool.
for tag in pairs(WEAPON_TAGS) do
	CollectionService:GetInstanceAddedSignal(tag):Connect(function(instance)
		task.defer(watchTool, instance, "tag ajouté : " .. tag)
	end)

	for _, instance in ipairs(CollectionService:GetTagged(tag)) do
		task.defer(watchTool, instance, "tag existant : " .. tag)
	end
end

print("[RuntimeWeaponTracer] Actif. Lance une manche puis attends Murderer/Sheriff.")
