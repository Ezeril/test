-- ServerScriptService > AllExistingWeaponHandles
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local CollectionService = game:GetService("CollectionService")

local output = ReplicatedStorage:FindFirstChild("WeaponHandles")

if not output then
	output = Instance.new("Folder")
	output.Name = "WeaponHandles"
	output.Parent = ReplicatedStorage
end

local saved = {}

local function cleanName(value)
	return tostring(value or "UnknownWeapon"):gsub("[^%w_%-]", "_")
end

local function findTool(instance)
	local current = instance

	while current and current ~= game do
		if current:IsA("Tool") then
			return current
		end

		current = current.Parent
	end
end

local function isWeapon(tool)
	if not tool or not tool:IsA("Tool") then
		return false
	end

	return tool:HasTag("Weapon")
		or tool:HasTag("Weapon_Gun")
		or tool:HasTag("Weapon_Knife")
		or tool:GetAttribute("IsWeapon") == true
		or tool:GetAttribute("IsGun") == true
		or tool:GetAttribute("IsKnife") == true
		or tool.Name == "Gun"
		or tool.Name == "Knife"
end

local function saveHandle(handle, reason)
	if not handle:IsA("BasePart") or handle.Name ~= "Handle" then
		return
	end

	local tool = findTool(handle)

	if not isWeapon(tool) then
		return
	end

	local itemId = tool:GetAttribute("ItemID")
	local itemName = tool:GetAttribute("ItemName")
	local key = cleanName(itemId or itemName or tool.Name)

	if saved[key] or output:FindFirstChild(key) then
		return
	end

	handle.Archivable = true

	local copy = handle:Clone()
	copy.Name = key
	copy:SetAttribute("ItemID", itemId or "")
	copy:SetAttribute("ItemName", itemName or tool.Name)
	copy:SetAttribute("ToolName", tool.Name)
	copy:SetAttribute("FoundAt", tool:GetFullName())
	copy:SetAttribute("Reason", reason)
	copy.Parent = output

	saved[key] = true

	print("[HANDLE TROUVE]", key, "->", copy:GetFullName())
end

-- Cherche dans tous les services accessibles au serveur.
for _, instance in ipairs(game:GetDescendants()) do
	saveHandle(instance, "scan initial")
end

-- Continue à récupérer ceux créés pendant les manches.
game.DescendantAdded:Connect(function(instance)
	task.defer(saveHandle, instance, "créé pendant le jeu")
end)

for _, tag in ipairs({ "Weapon", "Weapon_Gun", "Weapon_Knife" }) do
	CollectionService:GetInstanceAddedSignal(tag):Connect(function(tool)
		task.defer(function()
			local handle = tool:FindFirstChild("Handle", true)

			if handle then
				saveHandle(handle, "tag ajouté : " .. tag)
			end
		end)
	end)
end

print("[AllExistingWeaponHandles] Scan terminé. Regarde ReplicatedStorage.WeaponHandles")
